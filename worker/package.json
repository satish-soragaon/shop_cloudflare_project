{
  "name": "bookstore-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute bookstore-db --local --file=./migrations/0001_schema.sql",
    "db:seed": "wrangler d1 execute bookstore-db --local --file=./migrations/0002_seed.sql",
    "db:init:remote": "wrangler d1 execute bookstore-db --remote --file=./migrations/0001_schema.sql",
    "db:seed:remote": "wrangler d1 execute bookstore-db --remote --file=./migrations/0002_seed.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260529.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.95.0"
  }
}
